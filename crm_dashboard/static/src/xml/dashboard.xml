<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="crm_dashboard.CrmDashboard">
        <div style="overflow-y:auto;  max-height: 1000px;">
            <div class="row">
                <div class="col m-0 p-0">
                    <div class="shadow-sm border m-2 p-4 bg-white">
                        <div class="d-flex align-items-center justify-content-between">
                            <h1 class="text-primary fw-bold">Custom Sales Dashboard</h1>
                            <div>
                                <select class="form-select" t-on-change="event => this._renderChart(event.target.value)">
                                    <option value="7" selected="selected">This week</option>
                                    <option value="30">This month</option>
                                    <option value="90">This quarter</option>
                                    <option value="365">This year</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div>
                <div class="row main-section" style="margin-left: 100px;">
                    <!-- Lead Tile-->
                    <div id="leads" class="col-md-4 col-sm-6 tot_tasks oh-payslip"
                         style=" overflow: hidden; padding-top: 20px;">
                        <div class="oh-card"
                             style="box-shadow:2px 4px 8px 2px rgba(0,0,0.3,0.2); display: flex; justify-content: center;"
                             role="button" t-on-click="_onClickLead">
                            <div class="oh-card -body"
                                 style="padding: 5px 5px; float: left; width: 100%; height: auto; box-sizing: border-box; margin: 0;">
                                <div class="stat-widget-one">
                                    <div class="stat-icon bg-mauve-light d-flex justify-content-left align-items-left">
                                        <div style="background:#ff4d94; width:65px; text-align: center;">
                                            <i class="fa fa-tasks text-mauve" style="font-size:50px;"/>
                                        </div>
                                        <div class="stat_content"
                                             style="text-align: center; font-weight: bold; padding-top: 20px; padding-left: 80px;">
                                            <div class="stat_count_lead" style="font-size: 17px;">
                                                <span id="templates">
                                                    <t t-esc="state.data.total_leads"/>
                                                </span>
                                            </div>
                                            <div class="stat-head" style="font-size: 14px;">My Leads
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Opportunity Tile-->
                    <div id="opportunity" class="col-md-4 col-sm-6 tot_tasks oh-payslip"
                         style=" overflow: hidden; padding-top: 20px;">
                        <div class="oh-card"
                             style="box-shadow:2px 4px 8px 2px rgba(0,0,0.3,0.2); display: flex; justify-content: center;"
                             role="button" t-on-click="_onClickOpportunity">
                            <div class="oh-card-body"
                                 style="padding: 5px 5px; float: left; width: 100%; height: auto; box-sizing: border-box; margin: 0;">
                                <div class="stat-widget-one">
                                    <div class="stat-icon bg-mauve-light d-flex justify-content-left align-items-left">
                                        <div style="background:yellow; width:65px; text-align: center;">
                                            <i class="fa fa-trophy  text-mauve" style="font-size:50px;"/>
                                        </div>
                                        <div class="stat-content"
                                             style="text-align: center; font-weight: bold; padding-top: 20px; padding-left: 80px;">
                                            <div class="stat_count_opp" style="font-size: 17px;">
                                                <span id="templates">
                                                    <t t-esc="state.data.total_opportunity"/>
                                                </span>
                                            </div>
                                            <div class="stat-head" style="font-size: 14px;">My Opportunity
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div id="tot_revenue" class="col-md-4 col-sm-6 tot_tasks oh-payslip"
                         style=" overflow: hidden; padding-top: 20px;">
                        <div class="oh-card"
                             style="box-shadow:2px 4px 8px 2px rgba(0,0,0.3,0.2); display: flex; justify-content: center;"
                             role="button">
                            <div class="oh-card-body"
                                 style="padding: 5px 5px; float: left; width: 100%; height: auto; box-sizing: border-box; margin: 0;">
                                <div class="stat-widget-one">
                                    <div class="stat-icon bg-mauve-light d-flex justify-content-left align-items-left">
                                        <div style="background:yellow; width:65px; text-align: center;">
                                            <i class="fa fa-usd  text-mauve" style="font-size:50px;"/>
                                        </div>
                                        <div class="stat-content"
                                             style="text-align: center; font-weight: bold; padding-top: 20px; padding-left: 80px;">
                                            <div class="stat_count_opp" style="font-size: 17px;">
                                                <span id="templates">
                                                    <t t-esc="state.data.my_revenue"/>
                                                </span>
                                            </div>
                                            <div class="stat-head" style="font-size: 14px;">Revenue
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div id="ratio" class="col-md-4 col-sm-6 tot_tasks oh-payslip"
                         style=" overflow: hidden; padding-top: 20px;">
                        <div class="oh-card"
                             style="box-shadow:2px 4px 8px 2px rgba(0,0,0.3,0.2); display: flex; justify-content: center;"
                             role="button">
                            <div class="oh-card-body"
                                 style="padding: 5px 5px; float: left; width: 100%; height: auto; box-sizing: border-box; margin: 0;">
                                <div class="stat-widget-one">
                                    <div class="stat-icon bg-mauve-light d-flex justify-content-left align-items-left">
                                        <div style="background:#bf80ff;; width:65px; text-align: center;">
                                            <i class="fa fa-trophy  text-mauve" style="font-size:50px;"/>
                                        </div>
                                        <div class="stat-content"
                                             style="text-align: center; font-weight: bold; padding-top: 20px; padding-left: 80px;">
                                            <div class="stat_count_opp" style="font-size: 17px;">
                                                <span id="templates">
                                                    <div id="my_win_ratio"/>
                                                </span>
                                            </div>
                                            <div class="stat-head" style="font-size: 14px;">Win ratio
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Expected Revenue -->
                    <div id="expected_revenue" class="col-md-4 col-sm-6 tot_tasks oh-payslip"
                         style=" overflow: hidden; padding-top: 20px;">
                        <div class="oh-card"
                             style="box-shadow:2px 4px 8px 2px rgba(0,0,0.3,0.2); display: flex; justify-content: center;"
                             role="button">
                            <div class="oh-card-body"
                                 style="padding: 5px 5px; float: left; width: 100%; height: auto; box-sizing: border-box; margin: 0;">
                                <div class="stat-widget-one">
                                    <div class="stat-icon bg-mauve-light d-flex justify-content-left align-items-left">
                                        <div style="background:#bf80ff;; width:65px; text-align: center;">
                                            <i class="fa fa-usd  text-mauve" style="font-size:50px;"/>
                                        </div>
                                        <div class="stat-content"
                                             style="text-align: center; font-weight: bold; padding-top: 20px; padding-left: 80px;">
                                            <div class="stat_count_ex_rev" style="font-size: 17px;">
                                                <span id="templates">
                                                    <t t-esc="state.data.expected_revenue"/>
                                                </span>
                                            </div>
                                            <div class="stat-head" style="font-size: 14px;">Expected revenue
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <br/>
                <br/>
                <div class="container-fluid py-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body">
                                    <h6 class="card-title fw-bold mb-4 text-center">Activity</h6>
                                    <canvas id="chart_example"></canvas>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body">
                                    <h6 class="card-title fw-bold mb-4 text-center">Lost Lead/Opportunity</h6>
                                    <canvas id="chart_example2"></canvas>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body">
                                    <h6 class="card-title fw-bold mb-4 text-center">Leads by Medium</h6>
                                    <canvas id="chart_example3"></canvas>
                                </div>
                            </div>
                        </div>


                        <div class="col-md-6">
                            <div class="card h-100 shadow-sm" >

                                <div class="card-body" style="overflow: auto;  ">
                                     <h6 class="card-title fw-bold mb-4 text-center">Leads by Month</h6>
                                    <table class="table"  border="1">
                                        <thead>
                                            <tr>
                                                <th>Jan</th>
                                                <th>Feb</th>
                                                <th>Mar</th>
                                                <th>Apr</th>
                                                <th>May</th>
                                                <th>June</th>
                                                <th>July</th>
                                                <th>Aug</th>
                                                <th>Sept</th>
                                                <th>Oct</th>
                                                <th>Nov</th>
                                                <th>Dec</th>

                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td><t t-esc="state.period[0]"/></td>
                                                <td><t t-esc="state.period[1]"/></td>
                                                <td><t t-esc="state.period[2]"/></td>
                                                <td><t t-esc="state.period[3]"/></td>
                                                <td><t t-esc="state.period[4]"/></td>
                                                <td><t t-esc="state.period[5]"/></td>
                                                <td><t t-esc="state.period[6]"/></td>
                                                <td><t t-esc="state.period[7]"/></td>
                                                <td><t t-esc="state.period[8]"/></td>
                                                <td><t t-esc="state.period[9]"/></td>
                                                <td><t t-esc="state.period[10]"/></td>
                                                <td><t t-esc="state.period[11]"/></td>
                                            </tr>

                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>