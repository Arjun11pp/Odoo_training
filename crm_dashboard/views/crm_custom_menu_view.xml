<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="crm_dashboard_action" model="ir.actions.client">
        <field name="name">CRM Dashboard</field>
        <field name="tag">crm_dashboard_tag</field>
    </record>
    <record id="crm_dashboard_manager_action" model="ir.actions.client">
        <field name="name">CRM Dashboard for manager</field>
        <field name="tag">crm_dashboard_tag_manager</field>
    </record>
    <menuitem name="Dashboard" id="crm_dashboard" sequence="0"
               parent="crm.crm_menu_root"/>
    <menuitem name="Dashboard1" id="crm_dashboard1" sequence="1" action="crm_dashboard_action"
               parent="crm_dashboard"/>
    <menuitem name="Dashboard2" id="crm_dashboard2" sequence="2" action="crm_dashboard_manager_action"
               parent="crm_dashboard"  groups="crm_dashboard.group_use_recurring_revenues" />

</odoo>