<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_project_form_inherit_state" model="ir.ui.view">
        <field name="name">project.task.form.inherit.custom.state</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_ids']" position="after">
                <field name="task_state_id" domain="[('project_ids', 'in',project_id)]" />
            </xpath>
        </field>
    </record>
</odoo>