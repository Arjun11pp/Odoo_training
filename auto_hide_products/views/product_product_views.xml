<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_product_product_form_auto_hide" model="ir.ui.view">
        <field name="name">product.product.form.inherit.custom.button</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
             <xpath expr="//group[@name='extra_info']//field[@name='product_tag_ids']" position="after">
               <field name='auto_hide_products' string="Auto hide the product from website upon out of stock" widget="boolean_toggle"/>
           </xpath>
        </field>
    </record>
</odoo>