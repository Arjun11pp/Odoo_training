<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<record id="action_loan_management_line" model="ir.actions.act_window">
        <field name="name">Loan</field>
        <field name="res_model">employee.loan.line</field>
        <field name="view_mode">list,form</field>
    </record>

     <record id="view_loan_mangement_line" model="ir.ui.view">
        <field name="name">employee.loan.line.list</field>
        <field name="model">employee.loan.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="loan_id"/>
                <field name="date"/>
                <field name="amount"/>
                <field name="paid"/>

            </list>
        </field>
    </record>


     <record id="view_loan_mangement_line_form" model="ir.ui.view">
        <field name="name">employee.loan.line.form</field>
        <field name="model">employee.loan.line</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                       <field name="loan_id"/>
                <field name="date"/>
                <field name="amount"/>
                <field name="paid"/>

                    </group>


                </sheet>
            </form>
        </field>
    </record>

    </odoo>