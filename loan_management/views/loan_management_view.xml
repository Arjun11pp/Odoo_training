<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_loan_management" model="ir.actions.act_window">
        <field name="name">Loan</field>
        <field name="res_model">employee.loan</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_loan_mangement" model="ir.ui.view">
        <field name="name">employee.loan.list</field>
        <field name="model">employee.loan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="loan_amount"/>
                <field name="installment_count"/>
                <field name="start_date"/>
            </list>
        </field>
    </record>

    <record id="view_loan_mangement_form" model="ir.ui.view">
        <field name="name">employee.loan.form</field>
        <field name="model">employee.loan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" type="object" string="Approve" class="oe_highlight"
                            invisible="state in [ 'approved','ongoing','paid'] "/>
                    <button name="action_create_installment" type="object" string="Create Installment"
                            class="oe_highlight" invisible="state in [ 'draft','ongoing','paid'] "/>
                    <button name="action_pay_installment" type="object" string="Pay" class="oe_highlight"
                            invisible="state in [ 'draft','approved','paid'] "/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,ongoing,paid"/>
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button class="oe_stat_button" type="object" icon="fa-calendar"
                                name="action_get_loan_details" string="Count">
                            <field name="loan_line_ids_count" readonly="1"/>
                            <span style="white-space: pre;">Installments</span>
                        </button>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="employee_id" domain="[('employee_id.loan_not_allowed','=', False)]"/>
                        <field name="loan_amount"/>
                        <field name="installment_count"/>
                        <field name="start_date"/>
                        <field name="installment_amount"/>
                        <field name="total_payable"/>
                        <field name="paid_amount"/>
                        <field name="balance_amount"/>
                    </group>
                    <notebook>
                        <page string="Loan lines">
                            <field name="loan_line_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>