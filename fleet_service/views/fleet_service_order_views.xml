<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_fleet_service" model="ir.actions.act_window">
        <field name="name">Fleet</field>
        <field name="res_model">fleet.service.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_fleet_mangement" model="ir.ui.view">
        <field name="name">fleet.service.order.list</field>
        <field name="model">fleet.service.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="technician_id"/>
                <field name="service_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_fleet_mangement_form" model="ir.ui.view">
        <field name="name">fleet.service.order.form</field>
        <field name="model">fleet.service.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                         <button name="action_fleet_service_confirm" type="object" string="Confirm" class="oe_highlight"
                           invisible="state not in ['draft'] " />
                    <button name="action_fleet_service_generate" type="object" string="Generate" class="oe_highlight"
                           invisible="state not in ['confirmed'] " />
                    <button name="action_start_service" type="object" string="Start"
                            class="oe_highlight" invisible="state  in ['draft','progress','cancel','done'] " />
                    <button name="action_fleet_cancel" type="object" string="Cancel" class="oe_highlight"
                          invisible="state  in ['done','cancel'] "   />
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,progress,done"/>
                </header>
                <sheet>

                    <group>
                        <field name="name"/>
                <field name="vehicle_id"/>
                <field name="technician_id"/>
                <field name="service_date"/>
                <field name="parts_total"/>
                <field name="labour_cost"/>
                <field name="grand_total"/>
                <field name="check_list_progress"/>
                 <field name="type_ids" widget="many2many_tags"/>

                    </group>
                    <notebook>
                        <page string="Parts">
                            <field name="part_ids">
                             <list editable="bottom">
                                    <field name="order_id"/>
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                </list>
                            </field>
                        </page>
                        <page string="checklist">
                            <field name="checklist_ids">
                            <list editable="bottom">
                                    <field name="order_id"/>
                                    <field name="task_name"/>
                                    <field name="is_done"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>