<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<record id="view_sale_order_form_inherit_brand_field" model="ir.ui.view">
       <field name="name">sale.order.form.inherit.custom.field</field>
       <field name="model">sale.order</field>
       <field name="inherit_id" ref="sale.view_order_form"/>
       <field name="arch" type="xml">
           <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_qty']" position="after">
               <field name="brand_ids"/>
           </xpath>
       </field>
   </record>

     <record id="view_sale_order_form_inherit_custom_field" model="ir.ui.view">
       <field name="name">sale.order.form.inherit.custom.field</field>
       <field name="model">sale.order</field>
       <field name="inherit_id" ref="sale.view_order_form"/>
       <field name="arch" type="xml">
           <xpath expr="//field[@name='partner_shipping_id']" position="after">
               <field name='prime_customer_id' invisible="not partner_id"  />
           </xpath>
       </field>
   </record>

    <record id="view_sale_order_form_inherit_button2" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.custom.button</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_quotation_send']" position="after">
                <button type="object" string="Customer" name="action_customer_button"
                        class="oe_highlight"/>
            </xpath>
        </field>
    </record>

</odoo>