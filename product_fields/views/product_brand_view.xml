<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
     <record id="view_product_form_inherit_custom_field" model="ir.ui.view">
       <field name="name">product.template.form.inherit.custom.field</field>
       <field name="model">product.template</field>
       <field name="inherit_id" ref="product.product_template_only_form_view"/>
       <field name="arch" type="xml">
           <xpath expr="//field[@name='invoice_policy']" position="after">
               <field name='brand_id' invisible="product_master_type  in ['single'] or not product_master_type "/>
           </xpath>
       </field>
   </record>

    <record id="view_product_form_inherit_custom_field2" model="ir.ui.view">
       <field name="name">product.template.form.inherit.custom.field</field>
       <field name="model">product.template</field>
       <field name="inherit_id" ref="product.product_template_only_form_view"/>
       <field name="arch" type="xml">
           <xpath expr="//field[@name='invoice_policy']" position="after">
               <field name='product_master_type' />
           </xpath>
       </field>
   </record>

    <record id="view_product_list_inherit_custom_field" model="ir.ui.view">
       <field name="name">product.template.list.inherit.custom.field</field>
       <field name="model">product.template</field>
       <field name="inherit_id" ref="account.product_template_list_view_sellable_inherit"/>
       <field name="arch" type="xml">
           <xpath expr="//field[@name='default_code']" position="after">
               <field name='brand_id' />
           </xpath>
       </field>
   </record>

    <record id="view_product_form_inherit_custom_field3" model="ir.ui.view">
       <field name="name">product.product.form.inherit.custom.field</field>
       <field name="model">product.product</field>
       <field name="inherit_id" ref="product.product_normal_form_view"/>
       <field name="arch" type="xml">
           <xpath expr="//field[@name='default_code']" position="before">
<!--            <label for="average_cost"/>-->
               <field name='average_cost' widget="monetary" />
           </xpath>
       </field>
   </record>

</odoo>