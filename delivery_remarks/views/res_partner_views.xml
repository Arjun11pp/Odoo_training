<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_res_partner_form_inherit_custom" model="ir.ui.view">
       <field name="name">res.partner.form.inherit.custom.field</field>
       <field name="model">res.partner</field>
       <field name="inherit_id" ref="base.view_partner_form"/>
       <field name="arch" type="xml">
           <xpath expr="//field[@name='property_delivery_carrier_id']" position="after">
               <field name='most_product_sold'/>
               <field name="total_sold_quantity"/>
               <field name="minimum_sale_price"/>
               <field name="maximum_sale_price"/>
           </xpath>
       </field>
   </record>
</odoo>