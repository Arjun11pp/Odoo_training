<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="survey_fill_time_limit" inherit_id="survey.survey_fill_header">
            <xpath expr="//div[hasclass('o_survey_timer')]" position="before">
                <div class="o_survey_form_content_data_idle d-none"
                      t-att-data-idle-timer_limit="survey.idle_timer"
                      t-att-data-timer_idle="survey.timer_now"/>
                                    <div id="safeTimer">
                    <h2> Timer</h2>
                    <p id="safeTimerDisplay">00:00</p>
                    </div>

            </xpath>

        </template>
    </data>
</odoo>