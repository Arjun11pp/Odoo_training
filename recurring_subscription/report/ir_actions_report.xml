<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_recurring_subscription" model="ir.actions.report">
        <field name="name">Subscription Report</field>
        <field name="model">recurring.subscription</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">recurring_subscription.report_subscription_template</field>
        <field name="report_file">recurring_subscription.report_subscription_template</field>
        <field name="print_report_name">'Recurring subscription Report - %s' % (object.name)</field>
        <field name="binding_model_id" ref="recurring_subscription.model_recurring_subscription"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_report_recurring_subscription_credit" model="ir.actions.report">
        <field name="name">Credit Report</field>
        <field name="model">recurring.subscription.credit</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">recurring_subscription.report_subscription_credit_template</field>
        <field name="report_file">recurring_subscription.report_subscription_credit_template</field>
        <field name="print_report_name">'Recurring subscription Credit Report - %s' % (object.recurring_subscription_id)</field>
        <field name="binding_model_id" ref="recurring_subscription.model_recurring_subscription_credit"/>
        <field name="binding_type">report</field>
    </record>
</odoo>