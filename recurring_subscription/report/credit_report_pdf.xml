<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_subscription_credit_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure"/>
                        <h2>Subscription credit Report</h2>
                        <br/>
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>
                                        <p>
                                            <strong>SL.No:</strong>
                                        </p>
                                    </th>
                                    <th>
                                        <p>
                                            <strong>Subscription:</strong>
                                        </p>
                                    </th>
                                    <th>
                                        <p>
                                            <strong>Customer:</strong>
                                        </p>
                                    </th>
                                    <th>
                                        <p>
                                            <strong>Amount Applied:</strong>
                                        </p>
                                    </th>
                                    <th>
                                        <p>
                                            <strong>Amount Pending:</strong>
                                        </p>
                                    </th>
                                    <th>
                                        <p>
                                            <strong>State:</strong>
                                        </p>
                                    </th>
                                </tr>
                            </thead>
                            <tr>
                                <td>
                                    <span t-field="o.id"/>
                                </td>
                                <td>
                                    <span t-field="o.recurring_subscription_id"/>
                                </td>
                                <td>
                                    <span t-field="o.partner_id"/>
                                </td>
                                <td>
                                    <span t-field="o.credit_amount"/>
                                </td>
                                <td>
                                    <span t-field="o.credit_amount"/>
                                </td>
                                <td>
                                    <span t-field="o.state"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>