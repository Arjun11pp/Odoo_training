<?xml version="1.0" encoding="utf-8"?>
<odoo>
   <template id="report_subscription_template">
       <t t-call="web.html_container">
           <t t-foreach="docs" t-as="o">
               <t t-call="web.external_layout">
                   <div class="page">
                       <div class="oe_structure"/>
                       <h2>Subscription Report</h2>
                       <br/>
                       <table class="table" border="1">
                            <thead>
                           <tr>
                       <th><p><strong>SL.No:</strong></p> </th>
                       <th><p><strong>Name:</strong></p> </th>
                       <th><p><strong>Customer:</strong></p></th>
                       <th><p><strong>Product:</strong></p> </th>
                       <th><p><strong>Amount:</strong></p>  </th>
                       <th><p><strong>Total Credit Applied:</strong></p></th>
                       <th><p><strong>State:</strong></p> </th>
                   </tr>
                            </thead>
                    <tr>
                       <td><span t-field="o.sequence_number"/></td>
                        <td> <span t-field="o.name"/></td>
                        <td><span t-field="o.customer_id"/></td>
                        <td><span t-field="o.product_id"/></td>
                        <td><span t-field="o.recurring_amount"/> </td>
                        <td><span t-field="o.total_credit"/></td>
                        <td><span t-field="o.state"/></td>
                        </tr>
                        <tr><thead>
                            <th><br/><br/><br/><br/><strong>Terms and Conditions:</strong> </th>
                        </thead><td><span t-field="o.terms_and_conditions"/></td></tr>
                       </table>
                   </div>
               </t>
           </t>
       </t>
   </template>
</odoo>