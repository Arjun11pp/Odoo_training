<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="company_view_rule_user" model="ir.rule">
            <field name="name">Restrict company wise view</field>
            <field name="model_id" ref="model_recurring_subscription"/>
            <field name="domain_force">[('company_id', 'in', company_ids + [False] )]</field>
        </record>

        <record model="ir.module.category" id="module_category_recurring_subscription">
            <field name="name">Recurring Subscription</field>
            <field name="sequence">5</field>
        </record>
        <record model="res.groups.privilege" id="res_groups_privilege_recurring_subscription">
            <field name="name">Subscription</field>
            <field name="category_id" ref="recurring_subscription.module_category_recurring_subscription"/>
        </record>

        <record id="group_recurring_subscription_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="res_groups_privilege_recurring_subscription"/>
        </record>

        <record id="group_recurring_subscription_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_recurring_subscription"/>
            <field name="implied_ids" eval="[(4, ref('group_recurring_subscription_user'))]"/>
<!--            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>-->
        </record>
    </data>
</odoo>