<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="billing_schedule_view_search" model="ir.ui.view">
        <field name="name">billing.schedule.search</field>
        <field name="model">billing.schedule</field>
        <field name="arch" type="xml">
            <search string="Search credit">
                <field name="name"/>
                <field name="recurring_subscription_ids"/>
                <filter string="Archived " name="state" domain="[ ('active', '=', False )]"/>
                <filter string="Customers" name="group_by_customer" context="{'group_by':'restrict_customer'}"/>
            </search>
        </field>
    </record>

    <record id="action_billing_schedule" model="ir.actions.act_window">
        <field name="name">Billing Schedule</field>
        <field name="res_model">billing.schedule</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="recurring_subscription_billing_schedule_list" model="ir.ui.view">
        <field name="name">billing.schedule.list</field>
        <field name="model">billing.schedule</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
                <field name="simulation"/>
                <field name="period"/>
                <field name="restrict_customer"/>
                <field name="recurring_subscription_ids" widget="many2many_tags"/>
                <field name="currency_id" invisible="1" optional="hide"/>
                <field name="total_credit" widget="monetary"/>
            </list>
        </field>
    </record>

    <record id="recurring_subscription_billing_schedule_form" model="ir.ui.view">
        <field name="name">billing.schedule.form</field>
        <field name="model">billing.schedule</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button type="object" string="Create Invoice" name='action_create_billing_invoice'
                            class="oe_highlight" />
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button class="oe_stat_button" type="object"
                                icon="fa-indent" name="action_get_recurring_subscriptions" string="Count">
                            <field name="count" string="Subscription Count"/>
                            <span style="white-space: pre;"> Subscriptions</span>
                        </button>
                        <button class="oe_stat_button" type="object" icon="fa-pencil-square-o"
                                name="action_get_invoice" string="Count">
                            <span style="white-space: pre;">Invoice</span>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="simulation"/>
                            <field name="period"/>
                            <field name="restrict_customer" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="recurring_subscription_ids" widget="many2many_tags" domain="[('state', '=', 'confirm')]"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="total_credit" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="credit list">
                            <field name="credit_ids">
                                <list>
                                    <field name="recurring_subscription_id"/>
                                    <field name="partner_id"/>
                                    <field name="state"/>
                                    <field name="create_date"/>
                                    <field name="due_date"/>
                                    <field name="period_date"/>
                                    <field name="credit_amount"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
              <chatter/>
            </form>
        </field>
    </record>
</odoo>