<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="subscription_list" name="Customer Subscription List">
            <t t-call="website.layout">
                <div class="container my-5">
                    <h3 class="text-center mb-4">Recurring Subscriptions</h3>
                    <div class="mt-3">
                        <a href="/website/subscription/form" class="btn btn-primary rounded-3">Create New</a>
                    </div>
                    <br/>
                    <div class="table-responsive shadow-sm rounded-4 bg-white p-4">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="fw-semibold">Name</th>
                                    <th class="fw-semibold">Customer</th>
                                    <th class="fw-semibold text-center">Amount</th>
                                    <th class="fw-semibold">Product</th>
                                    <th> </th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="subscriptions" t-as="sub">
                                    <tr>
                                        <td>
                                            <t t-esc="sub.name"/>
                                        </td>
                                        <td>
                                            <t t-esc="sub.customer_id.name"/>
                                        </td>
                                        <td class="text-center">
                                            <t t-esc="sub.recurring_amount"/>
                                        </td>
                                        <td>
                                            <t t-esc="sub.product_id.name"/>
                                        </td>
                                        <td>
                                            <a t-att-href="/website/unique_subscriptions/views/{{ sub.id }}"  class="button-link">View</a>
                                        </td>
                                    </tr>
                                </t>
                                <t t-if="not subscriptions">
                                    <tr>
                                        <td>No subscriptions found.</td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </t>
        </template>

        <!-- Customer Create Form Template -->
        <template id="customer_form_template" name="Customer Form">
            <t t-call="website.layout">
                <section class="d-flex align-items-center justify-content-center vh-100"
                         style="background-color: #f8f9fa;">
                    <div class="card shadow-lg rounded-4" style="width: 400px;">
                        <div class="card-body p-5">
                            <h3 class="text-center mb-4">Create Recurring Subscription</h3>
                            <form action="/website/subscription/create" method="post">
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Name</label>
                                    <input type="text" name="name" class="form-control rounded-2" required="True"/>
                                </div>
                                <div>
                                    <label for="product_id">Choose a customer:</label>
                                    <select name="customer_id" class="form-select" required="True">
                                        <option value="" >-- Select an option --</option>
                                        <t t-foreach="customers" t-as="customer">
                                            <option t-att-value="customer.id">
                                                <t t-esc="customer.name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Amount</label>
                                    <input type="number" name="amount" class="form-control rounded-2" required="True"/>
                                </div>
                                <div>
                                    <label for="product_id">Choose a Product:</label>
                                    <select name="product_id" class="form-select" required="True">
                                        <option value="" >-- Select an option --</option>
                                        <t t-foreach="products" t-as="product">

                                            <option t-att-value="product.id">
                                                <t t-esc="product.name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <br/>
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary btn-block rounded-3 py-2">
                                        Submit
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </section>
            </t>
        </template>
        <!-- Success Page -->
        <template id="customer_success_template" name="Customer Created">
            <t t-call="website.layout">
                <section class="d-flex align-items-center justify-content-center vh-100"
                         style="background-color: #f8f9fa;">
                    <div class="text-center">
                        <h3 class="text-success mb-3">Subscription created Successfully!</h3>
                        <a href="/website/subscription/form" class="btn btn-primary rounded-3">Create another
                            subscription
                        </a>
                    </div>
                </section>
            </t>
        </template>
        <!-- Website Menu Record -->
        <record id="menu_customer_form" model="website.menu">
            <field name="name">Subscription</field>
            <field name="url">/website/subscriptions/view</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence" type="int">90</field>
        </record>
    </data>
</odoo>