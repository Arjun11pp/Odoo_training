<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <template id="billing_list" name="Billing Subscription List">
            <t t-call="website.layout">
                <div class="container my-5">
                    <h3 class="text-center mb-4">Recurring Subscriptions</h3>
                    <div class="mt-3">
                        <a href="/website/billing/form" class="btn btn-primary rounded-3">Create New</a>
                    </div>
                    <br/>
                    <div class="table-responsive shadow-sm rounded-4 bg-white p-4">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="fw-semibold">Name</th>
                                    <th class="fw-semibold">Subscriptions</th>
                                    <th class="fw-semibold">Total credits</th>
                                    <th class="fw-semibold text-center">period</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="billing" t-as="bill">
                                    <tr>
                                        <td>
                                            <t t-esc="bill.name"/>
                                        </td>
                                        <td>
                                            <t t-foreach="bill.recurring_subscription_ids" t-as="sub">
                                                <t t-esc="sub.name"/>,
                                            </t>
                                        </td>
                                        <td class="text-center">
                                            <t t-esc="bill.total_credit"/>
                                        </td>
                                        <td>
                                            <t t-esc="bill.period"/>
                                        </td>
                                    </tr>
                                </t>
                                <t t-if="not billing">
                                    <tr>
                                        <td>No Billings found.</td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </t>
        </template>

        <template id="billing_form_template" name="Customer Form">
            <t t-call="website.layout">
                <section class="d-flex align-items-center justify-content-center vh-100"
                         style="background-color: #f8f9fa;">
                    <div class="card shadow-lg rounded-4" style="width: 400px;">
                        <div class="card-body p-5">
                            <h3 class="text-center mb-4">Create Billing Schedule</h3>
                            <form action="/website/billings/create" method="post">
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Name</label>
                                    <input type="text" name="name" class="form-control rounded-2" required="True"/>
                                </div>
                                <div class="s_website_form_required">
                                    <label for="sub_ids">Choose the subscriptions :</label>
                                    <select name="sub_ids" t-attf-class="form-control select2_box" required="True" multiple="multiple">
                                        <t t-foreach="subscriptions" t-as="subscription">
                                            <option t-att-value="subscription.id">
                                                <t t-esc="subscription.name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <br/>
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary btn-block rounded-3 py-2">
                                        Submit
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </section>
            </t>
        </template>

        <template id="billing_success_template" name="Billing Created">
            <t t-call="website.layout">
                <section class="d-flex align-items-center justify-content-center vh-100"
                         style="background-color: #f8f9fa;">
                    <div class="text-center">
                        <h3 class="text-success mb-3">Billing created Successfully!</h3>
                        <a href="/website/billing/view" class="btn btn-primary rounded-3">Create another
                            Billing
                        </a>
                    </div>
                </section>
            </t>
        </template>

        <record id="menu_billing_form" model="website.menu">
            <field name="name">Billing</field>
            <field name="url">/website/billing/view</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence" type="int">90</field>
        </record>
    </data>
</odoo>