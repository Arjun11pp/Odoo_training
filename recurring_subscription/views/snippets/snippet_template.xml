<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <template id="category_template_highlight" name="Credit List">
       <section class="categories_section">
           <div class="container">
               <div class="alert alert-info">
                   <h4>Your Credit list will be displayed here
                       Please save to view the snippet
                   </h4>
               </div>
           </div>
       </section>
   </template>
   <template id="category_highlight_snippet" inherit_id="website.snippets"
             name="Category Highlight Snippet">
       <xpath expr="//snippets[@id='snippet_groups']" position="inside">
           <t t-snippet="recurring_subscription.category_template_highlight"
              t-thumbnail="/recurring_subscription/static/src/images.jpeg"/>
       </xpath>
       <xpath expr="//snippets[@id='snippet_structure']" position="inside">
           <t t-snippet="recurring_subscription.category_template_highlight"/>
       </xpath>
   </template>
</odoo>