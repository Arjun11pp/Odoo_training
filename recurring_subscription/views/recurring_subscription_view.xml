<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="recurring_subscription_view_search" model="ir.ui.view">
        <field name="name">recurring.subscription.search</field>
        <field name="model">recurring.subscription</field>
        <field name="arch" type="xml">
            <search string="Search Subscription">
                <field name="establishment"/>
                <field name="product_id"/>
                <filter string="Done " name="state"
                        domain="[('state', '=', 'done')]"/>
                <filter string="today " name="today"
                         domain="[('date', '=', today)]"/>
                <filter string="Establishment" name="group_by_establishment" context="{'group_by':'establishment'}"/>
                <filter string="Product" name="group_by_product" context="{'group_by':'product_id'}"/>
                <filter string="Customers" name="group_by_customer" context="{'group_by':'customer_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_recurring_subscription" model="ir.actions.act_window">
        <field name="name">Subscriptions</field>
        <field name="res_model">recurring.subscription</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="recurring_subscription_list" model="ir.ui.view">
        <field name="name">recurring.subscription.list</field>
        <field name="model">recurring.subscription</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="name"/>
                <field name="establishment"/>
                <field name="product_id"/>
                <field name="date"/>
                <field name="due_date"/>
                <field name="next_billing_date"/>
                <field name="is_lead" optional="hide"/>
                <field name="customer_id"/>
                <field name="currency_id" optional="hide"/>
                <field name="recurring_amount" widget="monetary"/>
                <field name="state" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="recurring_subscription_form" model="ir.ui.view">
        <field name="name">recurring.subscription.form</field>
        <field name="model">recurring.subscription</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="oe_highlight"
                            invisible="state in [ 'cancel','confirm','done'] " groups="recurring_subscription.group_recurring_subscription_manager"/>
                    <button name="action_done" type="object" string="Done" class="oe_highlight"
                            invisible="state in [ 'draft','cancel','done'] " groups="recurring_subscription.group_recurring_subscription_manager"/>
                    <button name="action_cancel" type="object" string="cancel"
                            invisible="state in ['cancel','confirm','done'] " groups="recurring_subscription.group_recurring_subscription_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirm,done,cancel"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Done" invisible="state in ['draft','confirm','cancel']"/>
                    <h1><field name="sequence_number"/></h1>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="establishment"/>
                            <field name="product_id"/>
                            <field name="date"/>
                            <field name="due_date"/>
                        </group>
                        <group>
                            <field name="next_billing_date"/>
                            <field name="is_lead"/>
                            <field name="customer_id"/>
                            <field name="total_credit"/>
                            <field name="company_id"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="recurring_amount" widget="monetary"/>
                            <field name="billing_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Credit List">
                            <field name="credit_ids">
                                <list editable="bottom">
                                    <field name="partner_id"/>
                                    <field name="credit_amount"/>
                                    <field name="state"/>
                                    <field name="period_date"/>
                                </list>
                            </field>
                        </page>
                        <page string="Terms and conditions">
                            <field name="terms_and_conditions"/>
                        </page>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>