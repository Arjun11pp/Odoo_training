<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_credit_report_wizard" model="ir.actions.act_window">
        <field name="name">Credit Report</field>
        <field name="res_model">credit.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="recurring_subscription.model_credit_report_wizard"/>
        <field name="binding_view_types">list,form</field>
    </record>

    <record id="recurring_credit_report_wizard_form" model="ir.ui.view">
        <field name="name">credit.report.wizard.form</field>
        <field name="model">credit.report.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="subscription_id" widget="many2many_tags"/>
                    <field name="state"/>
                </group>
                <footer>
                    <button string="Print PDF" name="action_credit_report_button"
                            type="object" class="btn-primary"/>
                    <button name="action_print_credit_xlsx" string="Print Excel"
                            type="object" class="btn-primary"/>
                    <button string="cancel" name="cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>