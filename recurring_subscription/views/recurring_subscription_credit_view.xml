<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="recurring_subscription_credit_view_search" model="ir.ui.view">
        <field name="name">recurring.subscription.credit.search</field>
        <field name="model">recurring.subscription.credit</field>
        <field name="arch" type="xml">
            <search string="Search credit">
                <field name="recurring_subscription_id"/>
                <field name="establishment_id"/>
                <filter string="Establishment" name="group_by_establishment" context="{'group_by':'establishment_id'}"/>
                <filter string="Customers" name="group_by_customer" context="{'group_by':'partner_id'}"/>
            </search>
        </field>
    </record>

    <!--    Recurring Subscription Credit -->
    <record id="action_recurring_subscription_credit" model="ir.actions.act_window">
        <field name="name">Recurring Subscription Credit</field>
        <field name="res_model">recurring.subscription.credit</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="recurring_subscription_credit_list" model="ir.ui.view">
        <field name="name">recurring.subscription.credit.list</field>
        <field name="model">recurring.subscription.credit</field>
        <field name="arch" type="xml">
            <list string="Channel">
                <field name="recurring_subscription_id"/>
                <field name="partner_id"/>
                <field name="establishment_id"/>
                <field name="due_date"/>
                <field name="currency_id" invisible="1" optional="hide"/>
                <field name="credit_amount" widget="monetary"/>
                <field name="state"/>
                <field name="period_date"/>
            </list>
        </field>
    </record>

    <record id="recurring_subscription_credit_form" model="ir.ui.view">
        <field name="name">recurring.subscription.credit.form</field>
        <field name="model">recurring.subscription.credit</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" options="{'clickable':1}" statusbar_visible="pending,confirmed,approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <field name="recurring_subscription_id" placeholder="Select"/>
                        <field name="partner_id"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="credit_amount" widget="monetary"/>
                        <field name="establishment_id"/>
                        <field name="due_date"/>
                        <field name="company_id"/>
                        <field name="period_date"/>
                        <field name="credit_image" widget="image" options="{'size': [150,150]}"/>
                    </group>
                </sheet>
               <chatter/>
            </form>
        </field>
    </record>
</odoo>