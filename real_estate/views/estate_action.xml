<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="estate_view_search" model="ir.ui.view">
        <field name="name">estate.property.search</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <search string="Search Opportunities">
                <field name="name"/>
                <field name="postcode"/>
                <field name="expected_price"/>
                <field name="bedrooms"/>
<!--                <field name="living_area"/>-->
                <field name="facades"/>
                <field name="living_area" string="Living area"
                        filter_domain="['|',('living_area', '>' , self),('living_area', '=' , self)]"/>
                <filter string="Available" name="active" domain="[('active', '=', True)]" />
                <filter string="Include archived" name="archived"
                        domain="['|', ('active', '=', True), ('active', '=', False)]"/>
                <!--                <separator/>-->
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <filter string="New or Offer received" name="state_new_offer"
                        domain="['|',('state', '=', 'new'),('state','=','offer')]"/>

                <filter string="PostCode" name="group_by_postcode" context="{'group_by':'postcode'}"/>

            </search>
        </field>
    </record>

    <record id="action_real_estate" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">list,form,kanban</field>
            <field name="context">{'search_default_active':True}</field>
    </record>

    <record id="view_estate_property_list" model="ir.ui.view">
        <field name="name">estate.property.list</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <list decoration-success="state in ['offer','accepted'] " decoration-bf="state=='accepted'" decoration-muted="state=='sold'">
                <field name="name"/>

                <field name="postcode"/>
                <field name="bedrooms"/>
                <field name="property_tag_id" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="living_area"/>
                <field name="expected_price"/>
                <field name="selling_price"/>
                <field name="date_availability" optional="hide"/>
                <field name="total"/>
            </list>
        </field>
    </record>

    <record id="estate_property_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form String="estate">
                <header>
                        <button name="sell" type="object" string="Sold" class="oe_highlight" invisible="not selling_price "/>
                        <button name="cancel" type="object" string="cancel" invisible="not selling_price " />
                      <field name="state" widget="statusbar" statusbar_visible="new,offer,accepted,sold"/>
                    </header>
                <sheet>

                    <h1>
                        <field name="name" placeholder="Property Name"/>
                    </h1>
                    <field name="property_tag_id" widget="many2many_tags" options="{'no_create':True,'color_field': 'color'}" placeholder="Select Property Tags"/>
                    <separator/>
                    <group colspan="1">
                        <group rowspan="1">
                            <field name="state"/>
                            <field name="postcode"/>
                            <field name="date_availability"/>
                            <field name="property_type_id" options="{'no_create':True}"/>
                        </group>
                        <group rowspan="2">
                            <field name="expected_price"/>
                            <field name="selling_price"/>
                            <field name="best_price"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <group>
                            <group>
                                <field name="description" placeholder=" Description"/>
                                <field name="bedrooms"/>
                                <field name="living_area"/>
                                <field name="facades"/>
                                <field name="garage"/>
                            </group>
                            <group>
                                <field name="garden"/>
                                <field name="garden_area" invisible="garden == False"/>
                                <field name="garden_orientation" placeholder=" select the" invisible="garden == False"/>
                                <field name="active"/>
                                <field name="state"/>
                                <field name="total"/>
                            </group>
                        </group>
                        </page>

                        <page string="Offer">
                            <field name="offer_ids" readonly="state in['accepted' , 'sold' , 'cancelled']">
                                <list editable="bottom" decoration-danger="status == 'refused'" decoration-success="status == 'accepted'">
                                    <field name="price"/>
                                    <field name="partner_id"/>
                                    <field name="property_type_id"/>
                                    <field name="create_date"/>
                                    <field name="date_deadline"/>
                                    <field name="validity"/>
                                     <button name="action_confirm"  title="Confirm" type="object" icon="fa-check" invisible="status" />
                                     <button name="action_cancel" title="cancel" states="draft" type="object" icon="fa-close" invisible="status" />
                                </list>
                            </field>

                        </page>
                        <page string="Other Info">
                            <group>
                                <field name="property_salesman_id"/>
                                <field name="property_buyer_id"/>
                            </group>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!--    Property types-->
    <record id="action_real_estate_settings" model="ir.actions.act_window">
        <field name="name">Property Types</field>
        <field name="res_model">real.estate.type</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="view_estate_property_types" model="ir.ui.view">
        <field name="name">estate.property.type.list</field>
        <field name="model">real.estate.type</field>
        <field name="arch" type="xml">
            <list>
                 <field name="sequence" widget="handle"/>
                <field name="name"/>
                 <field name="offer_ids"/>
                                    <field name="offer_count"/>
            </list>
        </field>
    </record>

    <!--    Property tag-->
    <record id="action_real_estate_tag" model="ir.actions.act_window">
        <field name="name">Property Tag</field>
        <field name="res_model">real.estate.tag</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="view_estate_property_tag" model="ir.ui.view">
        <field name="name">estate.property.tag.list</field>
        <field name="model">real.estate.tag</field>
        <field name="arch" type="xml">
            <list editable="bottom">

                <field name="name"/>
            </list>


        </field>
    </record>

