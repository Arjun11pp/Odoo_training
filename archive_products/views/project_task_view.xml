<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

<record id="view_project_form_inherit_button" model="ir.ui.view">
        <field name="name">project.task.form.inherit.custom.button</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
             <xpath expr="//field[@name='task_properties']" position="before">
              <group> <field name='hours_per_day' /></group>
           </xpath>
        </field>
    </record>
</odoo>