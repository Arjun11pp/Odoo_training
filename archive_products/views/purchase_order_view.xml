<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_purchase_order_form_field" model="ir.ui.view">
       <field name="name">purchase.order.form.inherit.custom.field</field>
       <field name="model">purchase.order</field>
       <field name="inherit_id" ref="purchase.purchase_order_form"/>
       <field name="arch" type="xml">
           <xpath expr="//field[@name='partner_ref']" position="after">
               <field name='restricted' invisible="restricted == False"/>
               <field name='restricted_count' invisible="restricted == False"/>

           </xpath>
       <xpath expr="//button[@name='button_cancel']" position="after">
                <button type="object" string="Add"
                        class="oe_highlight"  name="action_add" />
            </xpath>
       </field></record>
</odoo>